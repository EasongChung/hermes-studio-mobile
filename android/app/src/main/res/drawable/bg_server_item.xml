<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/hermes_surface_selected" />
            <stroke
                android:width="1.5dp"
                android:color="@color/hermes_accent" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/hermes_surface_elevated" />
            <stroke
                android:width="1dp"
                android:color="@color/hermes_border" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
