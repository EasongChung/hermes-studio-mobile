<?xml version="1.0" encoding="utf-8"?>
<!-- item_server.xml - 服务器列表项布局（深色指挥台卡片） -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:background="@drawable/bg_server_item"
    android:layout_marginBottom="10dp"
    android:elevation="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?selectableItemBackground">

    <!-- 选择指示器 -->
    <TextView
        android:id="@+id/selectedIndicator"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="12dp"
        android:layout_gravity="center_vertical"
        android:textSize="16sp"
        android:textColor="@color/hermes_accent_soft"
        android:gravity="center" />

    <!-- 服务器信息 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/serverName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/hermes_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/serverUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/hermes_text_secondary"
            android:layout_marginTop="3dp" />
    </LinearLayout>

</LinearLayout>
