<?xml version="1.0" encoding="utf-8"?>
<!-- activity_config.xml - 服务器列表管理界面（APP 启动首页）
     设计方向：跟随系统浅/深主题的 Hermes 原生设置页
     - 低对比渐变背景 + 浮层卡片
     - 语义色资源自动适配系统白色/黑色主题
     - 倒计时自动登录可开关，秒数 2~15
     - 自动登录进行中时主按钮切换为「取消自动登录」 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_config_screen">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="18dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_config_header"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务器设置"
                android:textSize="22sp"
                android:textColor="@color/hermes_text_primary"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="选择服务器后连接，或开启倒计时自动进入"
                android:textSize="12sp"
                android:textColor="@color/hermes_text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/addServerBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ 添加"
            android:textSize="14sp"
            android:textColor="@color/hermes_accent_soft"
            android:textStyle="bold"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_add_chip" />
    </LinearLayout>

    <!-- 服务器列表区域 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/serverList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/emptyHint"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="暂无服务器\n点击右上角「+ 添加」配置第一台 Hermes 服务器"
        android:textSize="14sp"
        android:textColor="@color/hermes_text_muted"
        android:visibility="visible"
        android:lineSpacingExtra="6dp"
        android:padding="24dp" />

    <!-- ===== 倒计时自动登录设置区 ===== -->
    <LinearLayout
        android:id="@+id/autoLoginSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_card_surface"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:elevation="2dp"
        android:visibility="visible">

        <!-- 开关行：倒计时自动登录（始终可见） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="倒计时自动登录"
                    android:textSize="15sp"
                    android:textColor="@color/hermes_text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="开启后将自动连接当前选中的服务器"
                    android:textSize="11sp"
                    android:textColor="@color/hermes_text_muted" />
            </LinearLayout>

            <!-- 倒计时显示：仅倒计时进行中显示 -->
            <TextView
                android:id="@+id/countdownText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="48dp"
                android:gravity="center"
                android:textSize="14sp"
                android:textColor="@color/hermes_accent_soft"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginEnd="10dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_countdown_badge" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/autoLoginSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- 倒计时秒数设置：开关开启后显示，范围 2~15 秒 -->
        <LinearLayout
            android:id="@+id/countdownSettingsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="倒计时长（2~15 秒）"
                android:textSize="12sp"
                android:textColor="@color/hermes_text_secondary" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/countdownMinusBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="−"
                    android:textSize="20sp"
                    android:gravity="center"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:textColor="@color/hermes_accent_soft"
                    android:background="@drawable/btn_circle_outline" />

                <TextView
                    android:id="@+id/countdownDurationText"
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="5"
                    android:textSize="18sp"
                    android:textColor="@color/hermes_text_primary"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/countdownPlusBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:gravity="center"
                    style="@style/Widget.AppCompat.Button.Borderless"
                    android:textColor="@color/hermes_accent_soft"
                    android:background="@drawable/btn_circle_outline" />
            </LinearLayout>
        </LinearLayout>

        <!-- 兼容旧逻辑保留（默认隐藏，主按钮已承担「取消自动登录」） -->
        <Button
            android:id="@+id/cancelCountdownBtn"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:text="取消自动登录"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 连接 / 取消自动登录 按钮 -->
    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="连接当前服务器"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:textColor="@color/hermes_on_action"
        android:background="@drawable/bg_btn_connect"
        android:stateListAnimator="@null"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:enabled="false" />

    <!-- ===== 项目信息区 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hermes Studio Mobile"
            android:textSize="11sp"
            android:textColor="@color/hermes_text_muted" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textSize="11sp"
            android:textColor="@color/hermes_text_muted" />

        <TextView
            android:id="@+id/githubLinkBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GitHub"
            android:textSize="11sp"
            android:textColor="@color/hermes_text_secondary"
            android:drawablePadding="3dp"
            android:drawableStart="@drawable/ic_github"
            android:clickable="true"
            android:focusable="true"
            android:background="?selectableItemBackground"
            android:padding="2dp" />
    </LinearLayout>

</LinearLayout>
