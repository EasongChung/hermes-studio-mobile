<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题：Material3 DayNight 主题，全屏无 ActionBar
         必须使用 Material3 主题，因为 layout 中使用了 Widget.Material3.* 组件
         （如 TextInputLayout OutlinedBox），AppCompat 主题会闪退 -->
    <style name="Theme.HermesStudioMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/hermes_primary</item>
        <item name="colorPrimaryVariant">@color/hermes_primary_dark</item>
        <item name="colorOnPrimary">@color/hermes_text_primary</item>
        <item name="colorSecondary">@color/hermes_accent</item>
        <item name="colorOnSecondary">@color/hermes_text_primary</item>
        <item name="android:statusBarColor">@color/hermes_primary</item>
        <item name="android:navigationBarColor">@color/hermes_primary</item>
        <item name="android:windowBackground">@color/hermes_primary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Splash 启动页主题：显示 Logo 背景消除白屏 -->
    <style name="Theme.HermesStudioMobile.Splash" parent="Theme.HermesStudioMobile">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
</resources>
