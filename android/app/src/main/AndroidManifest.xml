<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml
     声明 APP 组件、权限、硬件/软件特性。

     加载策略：本地加载前端，远程调用 API
     前端打包在 APK assets/hermes/ 中 file:// 本地加载，
     API 请求通过 WebView 跨源访问发往远程服务器。

     - INTERNET 权限：WebView 访问网络必需
     - usesCleartextTraffic：允许 HTTP 明文 API 请求
     - configChanges：横竖屏切换不重建 Activity
     - hardwareAccelerated：硬件加速提升 WebView 渲染性能 -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络访问权限（API 请求必需） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 网络状态访问权限（用于检测网络变化） -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HermesStudioMobile"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|keyboard|fontScale|mcc|mnc|touchscreen|navigation"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- LAUNCHER：桌面图标入口 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 服务器配置界面（服务器列表管理） -->
        <activity
            android:name=".ConfigActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 添加/编辑服务器界面 -->
        <activity
            android:name=".ServerEditActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
    </application>

</manifest>